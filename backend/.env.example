# Database
DATABASE_URL=sqlite:///./test.db

# Shopify API (get from your Shopify admin)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_REDIRECT_URI=http://localhost:3000/auth/callback

# VLM Extraction Backend
# Options:
# - "mock"      : Free, instant, uses keyword matching (good for testing)
# - "gpt4o"     : Uses GPT-4o-mini, requires OPENAI_API_KEY, $0.001/image
# - "local_vlm" : Uses Qwen2-VL-2B locally, FREE, no API costs (requires GPU)
#
# RECOMMENDED: local_vlm for free, unlimited extractions
EXTRACTION_BACKEND=local_vlm

# For gpt4o backend - get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Path to fine-tuned model (optional - uses base Qwen2-VL if empty)
FINE_TUNED_MODEL_PATH=